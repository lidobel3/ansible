global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h
  receiver: 'default'

receivers:
  - name: 'default'
    email_configs:
      - to: '{{ alertmanager_email_to }}'
        from: '{{ alertmanager_email_from }}'
        smarthost: 'localhost:25'
{% if alertmanager_slack_webhook %}
    slack_configs:
      - api_url: '{{ alertmanager_slack_webhook }}'
        channel: '#alerts'
        title: 'Alerte Prometheus'
{% endif %}

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'cluster', 'service']