# Configuration Prometheus
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'gcp-production'
    environment: '{{ ansible_environment | default("production") }}'

# Configuration Alertmanager
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - localhost:{{ alertmanager_port }}

# Règles d'alertes
rule_files:
  - "rules/*.yml"

# Targets à scraper
scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: 'alertmanager'
    static_configs:
      - targets: ['localhost:{{ alertmanager_port }}']

  - job_name: 'node_exporter'
      static_configs:
        - targets: ['localhost:9100']
        
  - job_name: 'nodes'
    static_configs:
      - targets: {{ prometheus_targets | to_json }}
